VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# If your Supabase dashboard still shows an anon key, you may use this instead:
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Local browser fallback for OpenRouter.
# For production, prefer the Supabase Edge Function secret below instead of exposing this key.
VITE_OPENROUTER_API_KEY=

VITE_OPENROUTER_MODEL="openai/gpt-4o"

# Used by Supabase Edge Function when serving locally with --env-file .env
OPENROUTER_API_KEY=
OPENROUTER_MODEL="openai/gpt-4o"